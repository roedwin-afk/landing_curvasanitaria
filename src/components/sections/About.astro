---
import { MapPin, Phone, Mail, CheckCircle } from 'lucide-astro';

const iconProps = { size: 20, strokeWidth: 1.5 };
const checkProps = { size: 18, strokeWidth: 2, color: 'var(--color-accent)' };

const features = [
  'Envíos a todo el territorio hondureño',
  'Soporte técnico para especificaciones',
  'Productos con certificación grado alimenticio',
  'Asesoría para ingenieros y contratistas',
  'Stock permanente en San Pedro Sula',
  'Atención personalizada B2B',
];

const cities = [
  { name: 'Tegucigalpa', region: 'Distrito Central' },
  { name: 'San Pedro Sula', region: 'Cortés' },
];
---

<section class="about section-padding" id="nosotros">
  <div class="container">

    <div class="about__grid">

      <!-- Columna izquierda: Texto SEO -->
      <div class="about__content" data-reveal="fade-right">
        <span class="about__label">Quiénes somos</span>
        <h2 class="about__title">
          Especialistas en Curvas Sanitarias en Honduras
        </h2>
        <p class="about__text">
          En el dinámico sector industrial de Honduras, desde la zona franca
          en Choloma hasta las plantas en Tegucigalpa, la higiene no es
          negociable. El uso de curvas sanitarias PVC es un requisito crítico
          para plantas que buscan certificaciones internacionales.
        </p>
        <p class="about__text">
          En EQUIPROH entendemos que el perfil sanitario PVC debe resistir el
          rigor del trabajo diario. Por eso, nuestros accesorios para cuartos
          fríos están fabricados bajo estándares estrictos que garantizan una
          larga vida útil incluso en condiciones críticas de humedad y
          temperatura.
        </p>

        <ul class="about__features">
          {features.map((feature) => (
            <li class="about__feature">
              <CheckCircle {...checkProps} />
              <span>{feature}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna derecha: Cobertura + Contacto -->
      <div class="about__sidebar" data-reveal="fade-left" data-reveal-delay="200">

        <div class="about__coverage">
          <h3 class="about__sidebar-title">Cobertura Nacional</h3>
          <div class="about__cities">
            {cities.map((city) => (
              <div class="about__city">
                <MapPin {...iconProps} color="var(--color-accent)" />
                <div>
                  <strong>{city.name}</strong>
                  <span>{city.region}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="about__contact">
          <h3 class="about__sidebar-title">Contáctenos</h3>
          <div class="about__contact-items">
            
            <a  href="https://wa.me/50431496022?text=Hola%20EQUIPROH%2C%20me%20interesa%20cotizar%20curvas%20sanitarias%20PVC"
              class="about__contact-item"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="about__contact-icon">
                <Phone {...iconProps} color="var(--color-accent)" />
              </div>
              <div>
                <strong>WhatsApp Honduras</strong>
                <span>+504 3149-6022</span>
              </div>
            </a>
            
            <a  href="mailto:ventas@equiproh.com"
              class="about__contact-item"
            >
              <div class="about__contact-icon">
                <Mail {...iconProps} color="var(--color-accent)" />
              </div>
              <div>
                <strong>Correo Electrónico</strong>
                <span>ventas@equiproh.com</span>
              </div>
            </a>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .about {
    background: var(--color-bg-soft);
  }

  .about__grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-16);
    align-items: start;
  }

  /* Columna izquierda */
  .about__label {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  .about__title {
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-4xl));
    margin-bottom: var(--space-6);
    line-height: 1.2;
  }

  .about__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .about__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .about__feature {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text);
    font-weight: 500;
  }

  .about__feature svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Sidebar */
  .about__sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about__coverage,
  .about__contact {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    border: 1px solid var(--color-border);
  }

  .about__sidebar-title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  /* Cities */
  .about__cities {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about__city {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .about__city svg {
    flex-shrink: 0;
  }

  .about__city strong {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
  }

  .about__city span {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Contact */
  .about__contact-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about__contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    transition: var(--transition);
    text-decoration: none;
  }

  .about__contact-item:hover {
    border-color: var(--color-accent);
    background: rgba(0, 112, 243, 0.03);
  }

  .about__contact-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: rgba(0, 112, 243, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .about__contact-item strong {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
  }

  .about__contact-item span {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Responsive */
  @media (max-width: 968px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .about__features {
      grid-template-columns: 1fr;
    }
  }
</style>