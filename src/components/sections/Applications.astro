---
const applications = [
  {
    title: 'Cuartos Fríos',
    description: 'Cámaras de refrigeración y congelación para la industria alimentaria hondureña.',
    image: 'https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=1200&q=80',
  },
  {
    title: 'Industria Cárnica',
    description: 'Plantas de procesamiento que requieren higiene máxima en pisos y paredes.',
    image: 'https://images.unsplash.com/photo-1607623814075-e51df1bdc82f?w=1200&q=80',
  },
  {
    title: 'Farmacéuticas',
    description: 'Laboratorios y plantas donde el control sanitario es crítico.',
    image: 'https://images.unsplash.com/photo-1563213126-a4273aed2016?w=1200&q=80',
  },
  {
    title: 'Cocinas Industriales',
    description: 'Cocinas B2B de hoteles, hospitales y cadenas de restaurantes.',
    image: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&q=80',
  },
  {
    title: 'Procesadoras de Mariscos',
    description: 'Plantas costeras con alta exposición a humedad y salmuera.',
    image: 'https://images.unsplash.com/photo-1498654200943-1088dd4438ae?w=1200&q=80',
  },
  {
    title: 'Zonas Francas',
    description: 'Industrias exportadoras en Choloma y SPS con estándares internacionales.',
    image: 'https://images.unsplash.com/photo-1587293852726-70cdb56c2866?w=1200&q=80',
  },
];
---

<section class="applications section-padding" id="aplicaciones">
  <div class="container">

    <div class="section-header">
      <h2>Sectores en Honduras</h2>
      <p>Nuestras soluciones operan en las industrias más exigentes del país.</p>
    </div>

    <div class="slider">

      <div class="slider__track" id="slider-track">
        {applications.map((app, i) => (
          <div class="slider__slide" data-index={i}>
            <img
              src={app.image}
              alt={app.title}
              width={1200}
              height={600}
              loading={i === 0 ? 'eager' : 'lazy'}
            />
            <div class="slider__overlay"></div>
            <div class="slider__content">
              <span class="slider__counter">{String(i + 1).padStart(2, '0')} / {String(applications.length).padStart(2, '0')}</span>
              <h3 class="slider__title">{app.title}</h3>
              <p class="slider__desc">{app.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Flechas -->
      <button class="slider__arrow slider__arrow--prev" id="slider-prev" aria-label="Anterior">
        &#8592;
      </button>
      <button class="slider__arrow slider__arrow--next" id="slider-next" aria-label="Siguiente">
        &#8594;
      </button>

      <!-- Indicador de progreso -->
      <div class="slider__progress">
        <div class="slider__progress-bar" id="slider-progress"></div>
      </div>

    </div>

  </div>
</section>

<script>
  const track    = document.getElementById('slider-track') as HTMLElement;
  const prevBtn  = document.getElementById('slider-prev') as HTMLButtonElement;
  const nextBtn  = document.getElementById('slider-next') as HTMLButtonElement;
  const progress = document.getElementById('slider-progress') as HTMLElement;

  const total = track.children.length;
  let current = 0;

  function goTo(index: number) {
    current = (index + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    progress.style.width = `${((current + 1) / total) * 100}%`;
    prevBtn.disabled = false;
    nextBtn.disabled = false;
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));

  // Inicializar barra de progreso
  goTo(0);

  // Swipe touch support
  let startX = 0;

  track.addEventListener('touchstart', (e) => {
    startX = e.touches[0].clientX;
  }, { passive: true });

  track.addEventListener('touchend', (e) => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      diff > 0 ? goTo(current + 1) : goTo(current - 1);
    }
  }, { passive: true });
</script>

<style>
  .applications {
    background: var(--color-bg);
  }

  /* Slider wrapper */
  .slider {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  /* Track */
  .slider__track {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* Slide */
  .slider__slide {
    position: relative;
    min-width: 100%;
    height: 520px;
    flex-shrink: 0;
  }

  .slider__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .slider__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 37, 64, 0.15) 0%,
      rgba(10, 37, 64, 0.80) 100%
    );
  }

  /* Contenido sobre imagen */
  .slider__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-12) var(--space-16);
    color: #fff;
  }

  .slider__counter {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.15em;
    margin-bottom: var(--space-3);
  }

  .slider__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: 800;
    color: #fff;
    margin-bottom: var(--space-3);
    line-height: 1.1;
  }

  .slider__desc {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.8);
    max-width: 560px;
    line-height: 1.6;
  }

  /* Flechas */
  .slider__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    font-size: var(--text-xl);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
    z-index: 10;
  }

  .slider__arrow:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-50%) scale(1.08);
  }

  .slider__arrow--prev { left: var(--space-6); }
  .slider__arrow--next { right: var(--space-6); }

  /* Barra de progreso */
  .slider__progress {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(255, 255, 255, 0.2);
  }

  .slider__progress-bar {
    height: 100%;
    background: var(--color-accent);
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .slider__slide {
      height: 400px;
    }

    .slider__content {
      padding: var(--space-8);
    }

    .slider__arrow {
      width: 40px;
      height: 40px;
      font-size: var(--text-base);
    }
  }

  @media (max-width: 480px) {
    .slider__slide {
      height: 320px;
    }
  }
</style>