---
import { ArrowRight } from "lucide-astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { products } from "../../data/products";

import co100 from "../../assets/images/CO100-1.png";
import coaf100 from "../../assets/images/COAF-100-65.png";
import rin51223 from "../../assets/images/RIN-51223.png";
import co2ve100 from "../../assets/images/CO2VE-100.png";
import tap47379 from "../../assets/images/TAP-47379.png";

const imageMap: Record<string, ImageMetadata> = {
  "CO100-1.png": co100,
  "COAF-100-65.png": coaf100,
  "RIN-51223.png": rin51223,
  "CO2VE-100.png": co2ve100,
  "TAP-47379.png": tap47379,
};

const base = import.meta.env.BASE_URL;
const iconProps = { size: 16, strokeWidth: 2 };
---

<section class="catalog section-padding" id="catalogo">
  <div class="container">
    <div class="section-header" data-reveal="fade-up">
      <h2>Portafolio Técnico</h2>
      <p>
        Componentes certificados para acabados sanitarios de alto nivel en
        plantas industriales.
      </p>
    </div>

    <div class="catalog__grid">
      {
        products.map((product) => {
          const img = imageMap[product.imageKey];
          return (
            <a
              href={`${base}productos/${product.slug}`}
              class="product-card"
              data-reveal="fade-up"
              data-reveal-delay="100"
            >
              <div class="product-card__img">
                {img && (
                  <Image
                    src={img}
                    alt={product.name + " - EQUIPROH Honduras"}
                    width={350}
                    height={240}
                    class="product__img"
                    format="webp"
                    loading="eager"
                  />
                )}
              </div>

              <div class="product-card__body">
                <span class="product-card__code">{product.code}</span>
                <h3 class="product-card__name">{product.name}</h3>
                <p class="product-card__desc">{product.shortDescription}</p>
                <span class="product-card__cta">
                  {product.cta}
                  <ArrowRight {...iconProps} />
                </span>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .catalog {
    background: var(--color-bg-soft);
  }

  .catalog__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  /* Card */
  .product-card {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: var(--transition);
  }

  .product-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  /* Imagen */
  .product-card__img {
    position: relative;
    height: 220px;
    background: var(--color-bg-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .product-card__img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: var(--space-6);
    mix-blend-mode: multiply;
    transition: var(--transition);
  }

  .product-card:hover .product-card__img img {
    transform: scale(1.05);
  }

  /* Placeholder cuando no hay imagen */
  .product-card__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-bg-soft), #eef2f7);
  }

  .product-card__placeholder span {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-border);
    letter-spacing: -0.03em;
  }

  /* Body */
  .product-card__body {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-card__code {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-2);
  }

  .product-card__name {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .product-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    flex: 1;
    margin-bottom: var(--space-6);
  }

  .product-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    transition: var(--transition);
    margin-top: auto;
  }

  .product-card__cta:hover {
    gap: var(--space-3);
    color: var(--color-accent-hover);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .catalog__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .catalog__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
