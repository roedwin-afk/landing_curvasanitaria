---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowLeft, AlertTriangle } from 'lucide-astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Página no encontrada | EQUIPROH Honduras"
  description="La página que buscas no existe. Regresa al inicio y encuentra nuestras soluciones en curvas sanitarias PVC para Honduras."
>
  <section class="not-found">
    <div class="container not-found__inner">

      <div class="not-found__icon">
        <AlertTriangle size={48} strokeWidth={1.5} color="var(--color-accent)" />
      </div>

      <span class="not-found__code">404</span>

      <h1 class="not-found__title">Página no encontrada</h1>

      <p class="not-found__desc">
        La página que buscas no existe o fue movida. <br />
        Regresa al inicio y encuentra nuestras soluciones industriales.
      </p>

      <div class="not-found__actions">
        <a href={base} class="btn btn-primary">
          <ArrowLeft size={18} strokeWidth={2} />
          Volver al Inicio
        </a>
        <a href={`${base}#catalogo`} class="btn btn-outline">
          Ver Productos
        </a>
      </div>

      <div class="not-found__links">
        <p>O visita directamente:</p>
        <div class="not-found__quicklinks">
          <a href={`${base}#beneficios`}>Beneficios</a>
          <a href={`${base}#aplicaciones`}>Aplicaciones</a>
          <a href={`${base}#contacto`}>Contacto</a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(160deg, #f8fafc 0%, #ffffff 100%);
    padding-block: var(--space-20);
  }

  .not-found__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
  }

  .not-found__icon {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-lg);
    background: rgba(0, 112, 243, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0, 112, 243, 0.15);
  }

  .not-found__code {
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.04em;
    opacity: 0.08;
    margin-block: calc(-1 * var(--space-6));
  }

  .not-found__title {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    color: var(--color-primary);
  }

  .not-found__desc {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 480px;
  }

  .not-found__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-4);
  }

  .not-found__links {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .not-found__links p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .not-found__quicklinks {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  .not-found__quicklinks a {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: var(--transition);
  }

  .not-found__quicklinks a:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .not-found__actions {
      flex-direction: column;
      width: 100%;
    }

    .not-found__actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>